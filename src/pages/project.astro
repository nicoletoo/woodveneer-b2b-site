---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import CTASection from '../components/CTASection.astro';

const projects = [
	{
		title: "Luxury Hotel Lobby",
		category: "Hospitality",
		imageUrl: "https://images.pexels.com/photos/1457842/pexels-photo-1457842.jpeg?auto=compress&cs=tinysrgb&w=800",
		description: "Dramatic wall panels featuring natural Black & White Ebony Veneer creating a striking first impression for international guests."
	},
	{
		title: "Executive Furniture Collection",
		category: "Furniture",
		imageUrl: "https://images.pexels.com/photos/1350789/pexels-photo-1350789.jpeg?auto=compress&cs=tinysrgb&w=800",
		description: "High-end office furniture with engineered ebony veneer ensuring consistent luxury across 500+ pieces."
	},
	{
		title: "Residential Interior Design",
		category: "Interior Design",
		imageUrl: "https://images.pexels.com/photos/1643389/pexels-photo-1643389.jpeg?auto=compress&cs=tinysrgb&w=800",
		description: "Custom wall paneling and bespoke cabinetry showcasing the unique grain patterns of natural ebony veneer."
	},
	{
		title: "Boutique Restaurant Interior",
		category: "Hospitality",
		imageUrl: "/White_Ebony_Cabinet_(11).png?auto=compress&cs=tinysrgb&w=800",
		description: "Sophisticated dining environment enhanced with premium veneer wall features and custom millwork elements."
	},
	{
		title: "Corporate Office Renovation",
		category: "Commercial",
		imageUrl: "/Engineered_Black_&_White_Ebony_Veneer_(6).jpg?auto=compress&cs=tinysrgb&w=800",
		description: "Modern executive office space featuring engineered veneer panels maintaining consistent aesthetics across multiple floors."
	},
	{
		title: "Luxury Residential Villa",
		category: "Residential",
		imageUrl: "https://images.pexels.com/photos/1457842/pexels-photo-1457842.jpeg?auto=compress&cs=tinysrgb&w=800",
		description: "Exclusive villa project with natural ebony veneer applied to custom furniture, doors, and architectural details."
	},
	{
		title: "High-End Furniture Showroom",
		category: "Furniture",
		imageUrl: "https://images.pexels.com/photos/1350789/pexels-photo-1350789.jpeg?auto=compress&cs=tinysrgb&w=800",
		description: "Premium furniture display featuring Black & White Ebony Veneer pieces highlighting natural grain artistry."
	},
	{
		title: "Boutique Hotel Guest Rooms",
		category: "Hospitality",
		imageUrl: "https://images.pexels.com/photos/1643389/pexels-photo-1643389.jpeg?auto=compress&cs=tinysrgb&w=800",
		description: "200+ guest rooms outfitted with engineered veneer headboards and wall panels ensuring design consistency."
	},
	{
		title: "Designer Cabinet Collection",
		category: "Furniture",
		imageUrl: "/White_Ebony_Cabinet_(11).png?auto=compress&cs=tinysrgb&w=800",
		description: "Luxury cabinet line utilizing natural veneer to create unique, high-value decorative storage solutions."
	},
	{
		title: "Private Library & Study",
		category: "Residential",
		imageUrl: "/Engineered_Black_&_White_Ebony_Veneer_(6).jpg?auto=compress&cs=tinysrgb&w=800",
		description: "Sophisticated library featuring floor-to-ceiling ebony veneer paneling and custom built-in shelving."
	},
	{
		title: "Upscale Restaurant Bar",
		category: "Hospitality",
		imageUrl: "https://images.pexels.com/photos/1457842/pexels-photo-1457842.jpeg?auto=compress&cs=tinysrgb&w=800",
		description: "Statement bar front and back bar construction with dramatic ebony veneer creating memorable visual impact."
	},
	{
		title: "Contemporary Office Furniture",
		category: "Commercial",
		imageUrl: "https://images.pexels.com/photos/1350789/pexels-photo-1350789.jpeg?auto=compress&cs=tinysrgb&w=800",
		description: "Modern office furniture series with engineered veneer providing scalable production for large corporate orders."
	}
];

const categories = ["All Projects", "Hospitality", "Furniture", "Interior Design", "Commercial", "Residential"];
---

<Layout
	title="Project Gallery | Black & White Ebony Veneer Applications | woodveneer.net"
	description="Explore our portfolio of premium veneer applications in furniture, hospitality, residential, and commercial projects. See how Black & White Ebony Veneer elevates exceptional design."
>
	<Header />

	<Hero
		title="Featured Projects"
		subtitle="Discover how premium Black & White Ebony Veneer transforms exceptional furniture, hospitality, and interior design projects worldwide."
		imageUrl="https://images.pexels.com/photos/1643389/pexels-photo-1643389.jpeg?auto=compress&cs=tinysrgb&w=1920"
		height="medium"
	/>

	<section class="projects-section">
		<div class="container">
			<div class="projects-intro">
				<h2>Portfolio of Excellence</h2>
				<p>
					Our premium veneer materials have been specified for luxury projects across hospitality,
					residential, commercial, and furniture manufacturing sectors. Each project demonstrates
					our commitment to quality, consistency, and professional B2B partnership.
				</p>
			</div>

			<div class="categories-filter">
				{categories.map(category => (
					<button class={`category-btn ${category === 'All Projects' ? 'active' : ''}`}>
						{category}
					</button>
				))}
			</div>

			<div class="projects-grid">
				{projects.map(project => (
					<ProjectCard {...project} />
				))}
			</div>
		</div>
	</section>

	<section class="stats-section">
		<div class="container">
			<div class="stats-grid">
				<div class="stat-card">
					<div class="stat-number">500+</div>
					<div class="stat-label">Completed Projects</div>
				</div>

				<div class="stat-card">
					<div class="stat-number">50+</div>
					<div class="stat-label">Countries Served</div>
				</div>

				<div class="stat-card">
					<div class="stat-number">1000+</div>
					<div class="stat-label">B2B Partners</div>
				</div>

				<div class="stat-card">
					<div class="stat-number">15+</div>
					<div class="stat-label">Years Experience</div>
				</div>
			</div>
		</div>
	</section>

	<section class="testimonials-section">
		<div class="container">
			<h2 class="section-title">What Our Partners Say</h2>

			<div class="testimonials-grid">
				<div class="testimonial-card">
					<div class="testimonial-content">
						<p>
							"The consistency of woodveneer.net's engineered ebony veneer allowed us to complete
							a 200-room hotel project without any visual discrepancies. Their professional support
							and reliable delivery schedule were crucial to our success."
						</p>
					</div>
					<div class="testimonial-author">
						<strong>James Chen</strong>
						<span>Furniture Manufacturer, Singapore</span>
					</div>
				</div>

				<div class="testimonial-card">
					<div class="testimonial-content">
						<p>
							"For our luxury residential projects, we rely on woodveneer.net's natural ebony veneer.
							The grain quality and natural character are exceptional, allowing us to create truly
							bespoke interiors for discerning clients."
						</p>
					</div>
					<div class="testimonial-author">
						<strong>Maria Rodriguez</strong>
						<span>Interior Designer, Spain</span>
					</div>
				</div>

				<div class="testimonial-card">
					<div class="testimonial-content">
						<p>
							"As a furniture factory producing high-volume collections, we need reliable veneer supply
							with batch consistency. woodveneer.net consistently delivers the quality and service we
							require for our production schedules."
						</p>
					</div>
					<div class="testimonial-author">
						<strong>David Park</strong>
						<span>Production Manager, South Korea</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<CTASection
		title="Let's Create Your Next Project Together"
		description="Whether you're planning a luxury furniture collection, hospitality project, or bespoke interior design, our team is ready to support your vision with premium Black & White Ebony Veneer."
		ctaText="Discuss Your Project"
		ctaLink="/contact"
		background="dark"
	/>

	<Footer />
</Layout>

<style>
	.projects-section {
		padding: var(--spacing-xl) 0;
		background: var(--color-white);
	}

	.projects-intro {
		max-width: 900px;
		margin: 0 auto var(--spacing-xl);
		text-align: center;
	}

	.projects-intro h2 {
		margin-bottom: var(--spacing-md);
	}

	.projects-intro p {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--color-gray);
	}

	.categories-filter {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
		margin-bottom: var(--spacing-xl);
	}

	.category-btn {
		padding: 0.75rem 1.5rem;
		background: var(--color-white);
		color: var(--color-gray);
		border: 2px solid var(--color-ivory);
		border-radius: 50px;
		font-size: 0.95rem;
		font-weight: 500;
		transition: all 0.3s ease;
		cursor: pointer;
	}

	.category-btn:hover,
	.category-btn.active {
		background: var(--color-ebony);
		color: var(--color-ivory);
		border-color: var(--color-ebony);
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
		gap: var(--spacing-md);
	}

	.stats-section {
		padding: var(--spacing-xl) 0;
		background: var(--color-ivory);
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: var(--spacing-md);
	}

	.stat-card {
		text-align: center;
		padding: var(--spacing-md);
	}

	.stat-number {
		font-family: var(--font-heading);
		font-size: 4rem;
		font-weight: 700;
		color: var(--color-ebony);
		line-height: 1;
		margin-bottom: var(--spacing-sm);
	}

	.stat-label {
		font-size: 1.1rem;
		color: var(--color-gray);
		font-weight: 500;
	}

	.testimonials-section {
		padding: var(--spacing-xl) 0;
		background: var(--color-white);
	}

	.section-title {
		text-align: center;
		margin-bottom: var(--spacing-xl);
	}

	.testimonials-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
		gap: var(--spacing-md);
	}

	.testimonial-card {
		background: var(--color-ivory);
		padding: var(--spacing-lg);
		border-radius: 8px;
		box-shadow: 0 2px 12px rgba(26, 26, 26, 0.06);
		transition: all 0.3s ease;
	}

	.testimonial-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 4px 20px rgba(26, 26, 26, 0.12);
	}

	.testimonial-content {
		margin-bottom: var(--spacing-md);
	}

	.testimonial-content p {
		font-size: 1.05rem;
		line-height: 1.8;
		color: var(--color-gray);
		font-style: italic;
	}

	.testimonial-author {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.testimonial-author strong {
		font-size: 1.1rem;
		color: var(--color-ebony);
		font-weight: 600;
	}

	.testimonial-author span {
		font-size: 0.95rem;
		color: var(--color-light-gray);
	}

	@media (max-width: 1024px) {
		.projects-grid {
			grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		}

		.stat-number {
			font-size: 3rem;
		}
	}

	@media (max-width: 768px) {
		.projects-section,
		.stats-section,
		.testimonials-section {
			padding: var(--spacing-lg) 0;
		}

		.projects-intro {
			margin-bottom: var(--spacing-md);
		}

		.categories-filter {
			margin-bottom: var(--spacing-md);
		}

		.category-btn {
			padding: 0.625rem 1.25rem;
			font-size: 0.9rem;
		}

		.projects-grid {
			grid-template-columns: 1fr;
		}

		.stats-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.testimonials-grid {
			grid-template-columns: 1fr;
		}

		.section-title {
			margin-bottom: var(--spacing-md);
		}
	}
</style>

<script>
	const categoryButtons = document.querySelectorAll('.category-btn');

	categoryButtons.forEach(button => {
		button.addEventListener('click', () => {
			categoryButtons.forEach(btn => btn.classList.remove('active'));
			button.classList.add('active');
		});
	});
</script>
