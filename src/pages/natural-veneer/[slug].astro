---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import CTASection from '../../components/CTASection.astro';

export async function getStaticPaths() {
	return [
		{
			params: { slug: 'natural-ebony-veneer-premium' }
		}
	];
}

const { slug } = Astro.params;

// Mock product for demo - in production, would fetch from CMS or markdown files
const products: Record<string, any> = {
	'natural-ebony-veneer-premium': {
		product_name: 'Natural Black & White Ebony Veneer - Premium Grade',
		featured_image: 'https://images.pexels.com/photos/271711/pexels-photo-271711.jpeg?auto=compress&cs=tinysrgb&w=1200',
		gallery_images: [
			'https://images.pexels.com/photos/271711/pexels-photo-271711.jpeg?auto=compress&cs=tinysrgb&w=800',
			'https://images.pexels.com/photos/172289/pexels-photo-172289.jpeg?auto=compress&cs=tinysrgb&w=800',
			'https://images.pexels.com/photos/1643389/pexels-photo-1643389.jpeg?auto=compress&cs=tinysrgb&w=800'
		],
		short_description: 'Authentic natural wood veneer with unique grain patterns and dramatic black-and-white contrast for luxury furniture and high-end interior projects.',
		seo_title: 'Natural Black & White Ebony Veneer | Premium Grade | woodveneer.net',
		meta_description: 'Premium grade natural Black & White Ebony Veneer with unique grain patterns. Perfect for luxury furniture, interior design, and architectural projects worldwide.',
		specifications: {
			thickness: '0.5mm, 0.6mm, custom thickness available',
			width: '100mm - 640mm (varies by availability)',
			length: '2440mm - 3050mm standard, custom lengths available',
			backing: 'Paper backing, fleece backing, or unbacked upon request',
			moisture: '8-12% properly conditioned',
			grade: 'Premium A-grade'
		},
		content: `
			<h2>Natural Black & White Ebony Veneer - Premium Grade</h2>
			<p>Our premium natural Black & White Ebony Veneer represents the finest authentic wood veneer available, carefully selected from premium timber sources to ensure exceptional character and superior aesthetic value.</p>

			<h3>Product Characteristics</h3>
			<p><strong>Authenticity & Natural Character:</strong> Each sheet is a genuine piece of ebony timber, showcasing the natural variations that make ebony one of the world's most prized decorative woods. The dramatic black-and-white contrast is entirely natural, varying subtly from sheet to sheet.</p>

			<p><strong>Grain Patterns:</strong> Natural grain patterns ranging from straight grain to interlocked and figured grain, reflecting the organic growth characteristics of genuine ebony timber.</p>

			<p><strong>Color Range:</strong> Deep rich blacks contrasting with warm ivory and cream tones, creating the signature Black & White Ebony aesthetic prized in luxury applications.</p>

			<h3>Quality Standards</h3>
			<ul>
				<li>Premium A-grade quality</li>
				<li>Properly conditioned for stability</li>
				<li>Smooth, clean surfaces suitable for high-quality finishing</li>
				<li>Compatible with professional veneer bonding techniques</li>
				<li>Accepts stains, lacquers, and protective coatings beautifully</li>
			</ul>

			<h3>Ideal Applications</h3>
			<p><strong>Luxury Furniture Manufacturing:</strong> High-end table tops and decorative panels, custom cabinet doors for exclusive residences, bespoke furniture pieces requiring natural artistry, designer collections where uniqueness is valued.</p>

			<p><strong>Interior Design Projects:</strong> Feature walls in luxury residences, hotel lobbies and premium hospitality spaces, corporate executive offices and reception areas, architectural millwork and custom built-ins.</p>

			<p><strong>Decorative Applications:</strong> Fine art and sculpture displays, retail and gallery fixtures, luxury retail environments, bespoke interior elements.</p>

			<h3>Material Properties</h3>
			<p><strong>Workability:</strong> Excellent workability for veneering, accepting standard adhesives and compatible with professional veneer application methods.</p>

			<p><strong>Durability:</strong> Premium ebony is exceptionally durable and dense, providing long-lasting beauty and resistance to wear.</p>

			<p><strong>Finishing:</strong> Responds beautifully to all finishing methods including staining, lacquering, waxing, and oil finishes.</p>

			<h3>Ordering Information</h3>
			<ul>
				<li>Minimum Order: Sample quantities available for evaluation</li>
				<li>Lead Time: 3-4 weeks for standard orders, varies by quantity</li>
				<li>Shipping: Professionally packaged for international delivery</li>
				<li>Custom Specifications: Available for large projects</li>
			</ul>

			<h3>Why Choose Our Natural Veneer</h3>
			<ul>
				<li>Sourced from certified suppliers committed to sustainable forestry</li>
				<li>Personally selected for premium quality and grain characteristics</li>
				<li>Professionally processed to maintain natural beauty</li>
				<li>Backed by 15+ years of veneer supply expertise</li>
				<li>Supported by our professional B2B team</li>
			</ul>
		`
	}
};

const product = products[slug];

if (!product) {
	return Astro.redirect('/natural-veneer');
}
---

<Layout
	title={product.seo_title}
	description={product.meta_description}
>
	<Header />

	<Hero
		title={product.product_name}
		subtitle="Premium Grade Natural Ebony Veneer with Authentic Grain Patterns"
		imageUrl={product.featured_image}
		height="large"
		cta1Text="Request Samples"
		cta1Link="/contact"
	/>

	<article class="product-section">
		<div class="container">
			<div class="product-intro">
				<h1 class="product-title">{product.product_name}</h1>
				<p class="product-subtitle">{product.short_description}</p>
			</div>

			<div class="product-specs">
				<h2>Specifications</h2>
				<div class="specs-grid">
					<div class="spec-card">
						<h4>Thickness Options</h4>
						<p>{product.specifications.thickness}</p>
					</div>
					<div class="spec-card">
						<h4>Width Range</h4>
						<p>{product.specifications.width}</p>
					</div>
					<div class="spec-card">
						<h4>Length Range</h4>
						<p>{product.specifications.length}</p>
					</div>
					<div class="spec-card">
						<h4>Backing Options</h4>
						<p>{product.specifications.backing}</p>
					</div>
					<div class="spec-card">
						<h4>Moisture Content</h4>
						<p>{product.specifications.moisture}</p>
					</div>
					<div class="spec-card">
						<h4>Grade</h4>
						<p>{product.specifications.grade}</p>
					</div>
				</div>
			</div>

			<div class="product-details">
				<div class="product-body" set:html={product.content} />
			</div>

			{product.gallery_images && product.gallery_images.length > 0 && (
				<div class="product-gallery">
					<h2>Product Gallery</h2>
					<div class="gallery-grid">
						{product.gallery_images.map(image => (
							<div class="gallery-item">
								<img src={image} alt="Product gallery" />
							</div>
						))}
					</div>
				</div>
			)}

			<div class="product-footer">
				<a href="/natural-veneer" class="back-link">← Back to Natural Veneer</a>
			</div>
		</div>
	</article>

	<CTASection
		title="Request Natural Ebony Veneer Samples"
		description="Experience the authentic beauty of Natural Black & White Ebony Veneer firsthand. Contact us to receive samples, discuss your project requirements, and explore custom sizing options."
		ctaText="Request Samples"
		ctaLink="/contact"
		background="dark"
	/>

	<Footer />
</Layout>

<style>
	.product-section {
		padding: var(--spacing-xl) 0;
		background: var(--color-white);
	}

	.product-intro {
		max-width: 900px;
		margin: 0 auto var(--spacing-xl);
	}

	.product-title {
		font-size: clamp(2rem, 4vw, 3.5rem);
		color: var(--color-ebony);
		margin-bottom: var(--spacing-md);
	}

	.product-subtitle {
		font-size: 1.25rem;
		line-height: 1.8;
		color: var(--color-gray);
	}

	.product-specs {
		background: var(--color-ivory);
		padding: var(--spacing-lg);
		border-radius: 8px;
		margin-bottom: var(--spacing-xl);
	}

	.product-specs h2 {
		margin-bottom: var(--spacing-lg);
		color: var(--color-ebony);
	}

	.specs-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--spacing-md);
	}

	.spec-card {
		background: var(--color-white);
		padding: var(--spacing-md);
		border-radius: 8px;
		border-left: 4px solid var(--color-gold);
	}

	.spec-card h4 {
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
		color: var(--color-ebony);
	}

	.spec-card p {
		font-size: 0.95rem;
		color: var(--color-gray);
	}

	.product-details {
		max-width: 900px;
		margin: 0 auto var(--spacing-xl);
	}

	.product-body {
		font-size: 1.05rem;
		line-height: 1.8;
		color: var(--color-gray);
	}

	.product-body h2 {
		margin-top: var(--spacing-lg);
		margin-bottom: var(--spacing-md);
		color: var(--color-ebony);
	}

	.product-body h3 {
		margin-top: var(--spacing-md);
		margin-bottom: var(--spacing-sm);
		color: var(--color-ebony);
	}

	.product-body p {
		margin-bottom: var(--spacing-md);
	}

	.product-body ul,
	.product-body ol {
		margin: var(--spacing-md) 0;
		padding-left: 2rem;
	}

	.product-body li {
		margin-bottom: 0.75rem;
	}

	.product-gallery {
		margin-top: var(--spacing-xl);
	}

	.product-gallery h2 {
		margin-bottom: var(--spacing-lg);
		color: var(--color-ebony);
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: var(--spacing-md);
	}

	.gallery-item {
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 4px 16px rgba(26, 26, 26, 0.12);
		height: 320px;
		transition: all 0.3s ease;
	}

	.gallery-item:hover {
		transform: translateY(-4px);
		box-shadow: 0 6px 24px rgba(26, 26, 26, 0.18);
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.gallery-item:hover img {
		transform: scale(1.05);
	}

	.product-footer {
		margin-top: var(--spacing-xl);
		padding-top: var(--spacing-lg);
		border-top: 1px solid var(--color-ivory);
	}

	.back-link {
		display: inline-block;
		color: var(--color-ebony);
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.back-link:hover {
		color: var(--color-walnut);
	}

	@media (max-width: 768px) {
		.product-section {
			padding: var(--spacing-lg) 0;
		}

		.product-body {
			font-size: 1rem;
		}

		.gallery-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
