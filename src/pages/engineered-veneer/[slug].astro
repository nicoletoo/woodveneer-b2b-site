---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import CTASection from '../../components/CTASection.astro';

export async function getStaticPaths() {
	return [
		{
			params: { slug: 'engineered-ebony-veneer-commercial' }
		}
	];
}

const { slug } = Astro.params;

// Mock product for demo - in production, would fetch from CMS or markdown files
const products: Record<string, any> = {
	'engineered-ebony-veneer-commercial': {
		product_name: 'Engineered Black & White Ebony Veneer - Commercial Grade',
		featured_image: 'https://images.pexels.com/photos/1350789/pexels-photo-1350789.jpeg?auto=compress&cs=tinysrgb&w=1200',
		gallery_images: [
			'https://images.pexels.com/photos/1350789/pexels-photo-1350789.jpeg?auto=compress&cs=tinysrgb&w=800',
			'https://images.pexels.com/photos/271711/pexels-photo-271711.jpeg?auto=compress&cs=tinysrgb&w=800',
			'https://images.pexels.com/photos/1643389/pexels-photo-1643389.jpeg?auto=compress&cs=tinysrgb&w=800'
		],
		short_description: 'Consistent and reliable engineered veneer designed for large-scale commercial applications with uniform appearance and excellent batch consistency.',
		seo_title: 'Engineered Black & White Ebony Veneer | Commercial Grade | woodveneer.net',
		meta_description: 'Commercial grade engineered Black & White Ebony Veneer with consistent appearance. Perfect for furniture factories, hospitality, and large-scale projects.',
		specifications: {
			thickness: '0.5mm, 0.6mm, custom thickness available',
			width: '640mm standard (other widths available upon request)',
			length: '2440mm, 2800mm, 3050mm standard, custom lengths available',
			backing: 'Paper backing, fleece backing, phenolic backing, or custom backing solutions',
			moisture: '6-10% controlled for optimal stability',
			grade: 'Consistent A-grade'
		},
		content: `
			<h2>Engineered Black & White Ebony Veneer - Commercial Grade</h2>
			<p>Our commercial grade engineered Black & White Ebony Veneer is specifically designed for furniture manufacturers, interior contractors, and large-scale commercial projects requiring consistent quality across significant volumes.</p>

			<h3>Product Overview</h3>
			<p><strong>Consistency & Reliability:</strong> Through advanced manufacturing processes, we create veneer sheets with uniform grain patterns and color consistency, ensuring every piece in your production run maintains identical aesthetic appeal.</p>

			<p><strong>Batch Matching:</strong> Engineered veneer offers excellent batch-to-batch consistency, allowing confident reordering for replacement parts, product extensions, or follow-up projects with assurance that new material will match perfectly.</p>

			<p><strong>Production Efficiency:</strong> Designed for high-volume manufacturing with predictable performance, reducing waste from material variations and streamlining production workflows.</p>

			<h3>Quality Standards</h3>
			<ul>
				<li>Consistent A-grade quality across all sheets</li>
				<li>Uniform grain patterns and color distribution</li>
				<li>Superior dimensional stability compared to natural veneer</li>
				<li>Reduced waste during processing and application</li>
				<li>Enhanced durability for commercial applications</li>
			</ul>

			<h3>Key Advantages for B2B Buyers</h3>
			<p><strong>For Furniture Manufacturers:</strong> Predictable material costs enabling accurate budgeting, reduced production waste from material inconsistencies, easy reordering with batch matching for product lines, scalable supply supporting growth from 100 to 10,000+ pieces.</p>

			<p><strong>For Hospitality Projects:</strong> Unified aesthetics across hundreds of identical rooms, reliable supply chains supporting project timelines, cost-effective luxury for large installations, simplified quality control across all spaces.</p>

			<p><strong>For Commercial Contractors:</strong> Consistent appearance for multi-location installations, reliable lead times supporting project schedules, customizable dimensions for specific construction requirements, professional support for large-scale specifications.</p>

			<h3>Material Performance</h3>
			<p><strong>Dimensional Stability:</strong> Superior stability compared to natural veneer reduces warping and splitting risks during processing and application.</p>

			<p><strong>Processing Performance:</strong> Optimized for adhesive bonding with standard veneer equipment and professional application methods.</p>

			<p><strong>Finishing Options:</strong> Accepts all finishing methods including staining, lacquering, waxing, and industrial finishes.</p>

			<h3>Customization Capabilities</h3>
			<p>We offer flexible customization for large projects:</p>
			<ul>
				<li>Custom Sizes: Non-standard dimensions available</li>
				<li>Thickness Options: Tailored to your equipment specifications</li>
				<li>Backing Solutions: Paper, fleece, phenolic, or composite backings</li>
				<li>Grain Variations: Different grain patterns available upon request</li>
				<li>Volume Discounts: Tiered pricing for large orders</li>
			</ul>

			<h3>Ordering Information</h3>
			<ul>
				<li>Standard Lead Time: 2-3 weeks for regular orders</li>
				<li>Volume Orders: 4-6 weeks, custom specifications</li>
				<li>Minimum Order: 500 sheets (negotiable for long-term agreements)</li>
				<li>Shipping: Professional packaging for international delivery</li>
				<li>Payment Terms: Negotiable for B2B partnerships</li>
			</ul>

			<h3>Why Choose Our Engineered Veneer</h3>
			<ul>
				<li>15+ years of reliable B2B partnerships with manufacturers worldwide</li>
				<li>Proven performance across 500+ commercial projects</li>
				<li>Personalized support from dedicated account teams</li>
				<li>Flexible terms for volume orders and long-term supply agreements</li>
				<li>Certified sustainable sourcing practices</li>
			</ul>
		`
	}
};

const product = products[slug];

if (!product) {
	return Astro.redirect('/engineered-veneer');
}
---

<Layout
	title={product.seo_title}
	description={product.meta_description}
>
	<Header />

	<Hero
		title={product.product_name}
		subtitle="Commercial Grade Engineered Veneer with Consistent Appearance & Batch Matching"
		imageUrl={product.featured_image}
		height="large"
		cta1Text="Request Samples"
		cta1Link="/contact"
	/>

	<article class="product-section">
		<div class="container">
			<div class="product-intro">
				<h1 class="product-title">{product.product_name}</h1>
				<p class="product-subtitle">{product.short_description}</p>
			</div>

			<div class="product-specs">
				<h2>Technical Specifications</h2>
				<div class="specs-grid">
					<div class="spec-card">
						<h4>Thickness Options</h4>
						<p>{product.specifications.thickness}</p>
					</div>
					<div class="spec-card">
						<h4>Standard Width</h4>
						<p>{product.specifications.width}</p>
					</div>
					<div class="spec-card">
						<h4>Standard Lengths</h4>
						<p>{product.specifications.length}</p>
					</div>
					<div class="spec-card">
						<h4>Backing Options</h4>
						<p>{product.specifications.backing}</p>
					</div>
					<div class="spec-card">
						<h4>Moisture Content</h4>
						<p>{product.specifications.moisture}</p>
					</div>
					<div class="spec-card">
						<h4>Grade</h4>
						<p>{product.specifications.grade}</p>
					</div>
				</div>
			</div>

			<div class="product-details">
				<div class="product-body" set:html={product.content} />
			</div>

			{product.gallery_images && product.gallery_images.length > 0 && (
				<div class="product-gallery">
					<h2>Product Gallery</h2>
					<div class="gallery-grid">
						{product.gallery_images.map(image => (
							<div class="gallery-item">
								<img src={image} alt="Product gallery" />
							</div>
						))}
					</div>
				</div>
			)}

			<div class="product-footer">
				<a href="/engineered-veneer" class="back-link">← Back to Engineered Veneer</a>
			</div>
		</div>
	</article>

	<CTASection
		title="Partner With Us for Your Production Needs"
		description="Discuss volume pricing, custom specifications, and long-term supply agreements. Our team is ready to support your manufacturing success with reliable, high-quality engineered veneer."
		ctaText="Contact Sales Team"
		ctaLink="/contact"
		background="dark"
	/>

	<Footer />
</Layout>

<style>
	.product-section {
		padding: var(--spacing-xl) 0;
		background: var(--color-white);
	}

	.product-intro {
		max-width: 900px;
		margin: 0 auto var(--spacing-xl);
	}

	.product-title {
		font-size: clamp(2rem, 4vw, 3.5rem);
		color: var(--color-ebony);
		margin-bottom: var(--spacing-md);
	}

	.product-subtitle {
		font-size: 1.25rem;
		line-height: 1.8;
		color: var(--color-gray);
	}

	.product-specs {
		background: var(--color-ivory);
		padding: var(--spacing-lg);
		border-radius: 8px;
		margin-bottom: var(--spacing-xl);
	}

	.product-specs h2 {
		margin-bottom: var(--spacing-lg);
		color: var(--color-ebony);
	}

	.specs-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--spacing-md);
	}

	.spec-card {
		background: var(--color-white);
		padding: var(--spacing-md);
		border-radius: 8px;
		border-left: 4px solid var(--color-gold);
	}

	.spec-card h4 {
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
		color: var(--color-ebony);
	}

	.spec-card p {
		font-size: 0.95rem;
		color: var(--color-gray);
	}

	.product-details {
		max-width: 900px;
		margin: 0 auto var(--spacing-xl);
	}

	.product-body {
		font-size: 1.05rem;
		line-height: 1.8;
		color: var(--color-gray);
	}

	.product-body h2 {
		margin-top: var(--spacing-lg);
		margin-bottom: var(--spacing-md);
		color: var(--color-ebony);
	}

	.product-body h3 {
		margin-top: var(--spacing-md);
		margin-bottom: var(--spacing-sm);
		color: var(--color-ebony);
	}

	.product-body p {
		margin-bottom: var(--spacing-md);
	}

	.product-body ul,
	.product-body ol {
		margin: var(--spacing-md) 0;
		padding-left: 2rem;
	}

	.product-body li {
		margin-bottom: 0.75rem;
	}

	.product-gallery {
		margin-top: var(--spacing-xl);
	}

	.product-gallery h2 {
		margin-bottom: var(--spacing-lg);
		color: var(--color-ebony);
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: var(--spacing-md);
	}

	.gallery-item {
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 4px 16px rgba(26, 26, 26, 0.12);
		height: 320px;
		transition: all 0.3s ease;
	}

	.gallery-item:hover {
		transform: translateY(-4px);
		box-shadow: 0 6px 24px rgba(26, 26, 26, 0.18);
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.gallery-item:hover img {
		transform: scale(1.05);
	}

	.product-footer {
		margin-top: var(--spacing-xl);
		padding-top: var(--spacing-lg);
		border-top: 1px solid var(--color-ivory);
	}

	.back-link {
		display: inline-block;
		color: var(--color-ebony);
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.back-link:hover {
		color: var(--color-walnut);
	}

	@media (max-width: 768px) {
		.product-section {
			padding: var(--spacing-lg) 0;
		}

		.product-body {
			font-size: 1rem;
		}

		.gallery-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
