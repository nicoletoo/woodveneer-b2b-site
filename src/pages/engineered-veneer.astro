---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout
	title="Engineered Black & White Ebony Veneer | Consistent Quality | woodveneer.net"
	description="Engineered Black & White Ebony Veneer with consistent grain patterns and stable supply. Ideal for furniture factories, large-scale projects, and commercial interior applications."
>
	<Header />

	<Hero
		title="Engineered Black & White Ebony Veneer"
		subtitle="Consistent, reliable engineered veneer designed for commercial-scale manufacturing with uniform appearance and excellent batch consistency."
		cta1Text="Request Samples"
		cta1Link="/contact"
		cta2Text="View Projects"
		cta2Link="/project"
		imageUrl="/news-hero.jpg"
		height="large"
		overlayOpacity={0.35}
	/>

	<section class="product-intro">
		<div class="container">
			<div class="intro-grid">
				<div class="intro-text">
					<h2>Consistent Quality for Large-Scale Projects</h2>
					<p>
						Our Engineered Black & White Ebony wood Veneer is specifically designed to meet the demands
						of furniture manufacturers, interior contractors, and large-scale commercial projects
						requiring consistent appearance across significant volumes.
					</p>
					<p>
						Through advanced manufacturing processes, we create veneer sheets with uniform grain
						patterns and color consistency, ensuring that every piece in your production run maintains
						the same premium aesthetic. This reliability makes engineered veneer the ideal choice for
						furniture collections, hotel installations, and multi-unit residential developments.
					</p>
				</div>
				<div class="intro-image">
					<img src="/Engineered_Black_&_White_Ebony_Veneer_(3).jpg" alt="Engineered Ebony Veneer" />
				</div>
			</div>
		</div>
	</section>

	<section class="features-section">
		<div class="container">
			<h2 class="section-title">Key Features & Advantages</h2>

			<div class="features-grid">
				<div class="feature-item">
					<div class="feature-number">01</div>
					<h3>Consistent Grain Appearance</h3>
					<p>
						Uniform grain patterns and color distribution across all sheets ensure visual
						consistency throughout your entire project, from first piece to last.
					</p>
				</div>

				<div class="feature-item">
					<div class="feature-number">02</div>
					<h3>Excellent Batch Consistency</h3>
					<p>
						Reliable batch-to-batch consistency means you can reorder with confidence that new
						shipments will match previous deliveries perfectly.
					</p>
				</div>

				<div class="feature-item">
					<div class="feature-number">03</div>
					<h3>Scalable Production Support</h3>
					<p>
						Designed for high-volume manufacturing with stable supply capabilities to support
						your production schedules without material shortages.
					</p>
				</div>

				<div class="feature-item">
					<div class="feature-number">04</div>
					<h3>Superior Stability</h3>
					<p>
						Enhanced dimensional stability compared to natural veneer reduces waste from
						warping or splitting during processing and application.
					</p>
				</div>

				<div class="feature-item">
					<div class="feature-number">05</div>
					<h3>Cost-Effective Luxury</h3>
					<p>
						Achieve the premium ebony aesthetic at a more accessible price point while
						maintaining consistent quality standards throughout large projects.
					</p>
				</div>

				<div class="feature-item">
					<div class="feature-number">06</div>
					<h3>Customization Flexibility</h3>
					<p>
						Available in custom sizes, thicknesses, and backing options tailored to your
						specific manufacturing processes and equipment.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="specifications-section">
		<div class="container">
			<h2 class="section-title">Technical Specifications</h2>

			<div class="specs-grid">
				<div class="spec-card">
					<h4>Thickness Options</h4>
					<p>0.5mm, 0.6mm, custom thickness available</p>
				</div>

				<div class="spec-card">
					<h4>Standard Width</h4>
					<p>640mm (other widths available upon request)</p>
				</div>

				<div class="spec-card">
					<h4>Standard Length</h4>
					<p>2440mm, 2800mm, 3050mm, custom lengths available</p>
				</div>

				<div class="spec-card">
					<h4>Backing Options</h4>
					<p>Paper backing, fleece backing, phenolic backing, or custom backing solutions</p>
				</div>

				<div class="spec-card">
					<h4>Moisture Content</h4>
					<p>6-10% controlled for optimal stability</p>
				</div>

				<div class="spec-card">
					<h4>Grade</h4>
					<p>Consistent A-grade quality across all sheets</p>
				</div>

				<div class="spec-card">
					<h4>Grain Pattern</h4>
					<p>Engineered straight grain with consistent appearance</p>
				</div>

				<div class="spec-card">
					<h4>Minimum Order</h4>
					<p>Project quantities starting from 500 sheets (negotiable)</p>
				</div>
			</div>

			<div class="specs-note">
				<p>
					<strong>Production Advantage:</strong> Our engineered veneer offers predictable performance and
					consistent aesthetics ideal for furniture factories and contractors managing large-scale projects.
					Custom specifications including size, thickness, and backing can be tailored to your production
					requirements. Contact us to discuss volume pricing and long-term supply agreements.
				</p>
			</div>
		</div>
	</section>

	<section class="benefits-section">
		<div class="container">
			<h2 class="section-title">Why Furniture Manufacturers Choose Engineered Veneer</h2>

			<div class="benefits-grid">
				<div class="benefit-card">
					<div class="benefit-icon">📊</div>
					<h3>Production Efficiency</h3>
					<p>
						Consistent sizing and quality reduce waste and processing time. Uniform appearance
						eliminates the need for careful grain matching, accelerating production workflows.
					</p>
				</div>

				<div class="benefit-card">
					<div class="benefit-icon">💰</div>
					<h3>Cost Control</h3>
					<p>
						Predictable material costs and reduced waste contribute to better budget management.
						Lower price per sheet compared to natural veneer without compromising visual appeal.
					</p>
				</div>

				<div class="benefit-card">
					<div class="benefit-icon">📦</div>
					<h3>Reliable Supply</h3>
					<p>
						Stable inventory availability ensures your production schedules stay on track. Less
						vulnerability to natural timber supply fluctuations.
					</p>
				</div>

				<div class="benefit-card">
					<div class="benefit-icon">✨</div>
					<h3>Quality Assurance</h3>
					<p>
						Every sheet meets the same quality standards, simplifying quality control and ensuring
						customer satisfaction across your entire product range.
					</p>
				</div>

				<div class="benefit-card">
					<div class="benefit-icon">🔄</div>
					<h3>Easy Reordering</h3>
					<p>
						Confident reordering for replacement parts, product line extensions, or follow-up projects
						knowing new material will match perfectly.
					</p>
				</div>

				<div class="benefit-card">
					<div class="benefit-icon">🌐</div>
					<h3>Project Scalability</h3>
					<p>
						From 100 pieces to 10,000+ units, engineered veneer scales effortlessly to meet project
						demands of any size without aesthetic compromise.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="applications-section">
		<div class="container">
			<h2 class="section-title">Ideal Applications</h2>

			<div class="applications-grid">
				<div class="application-card">
					<div class="application-icon">🏭</div>
					<h3>Furniture Manufacturing</h3>
					<p>
						Perfect for furniture collections requiring consistent appearance across multiple
						units: bedroom sets, office furniture lines, and commercial furniture systems.
					</p>
				</div>

				<div class="application-card">
					<div class="application-icon">🏨</div>
					<h3>Hospitality Projects</h3>
					<p>
						Ideal for hotel guest rooms, restaurant interiors, and commercial venues where
						hundreds of identical pieces maintain unified design aesthetics.
					</p>
				</div>

				<div class="application-card">
					<div class="application-icon">🏢</div>
					<h3>Commercial Interiors</h3>
					<p>
						Reliable choice for office buildings, retail environments, and corporate facilities
						requiring large-scale wall paneling and millwork.
					</p>
				</div>

				<div class="application-card">
					<div class="application-icon">🏘️</div>
					<h3>Multi-Unit Developments</h3>
					<p>
						Excellent for residential developments, apartment buildings, and condominiums where
						multiple units receive identical interior finishes.
					</p>
				</div>

				<div class="application-card">
					<div class="application-icon">🚪</div>
					<h3>Door Manufacturing</h3>
					<p>
						Consistent quality for door skin production ensuring uniformity across large door
						manufacturing runs and replacement orders.
					</p>
				</div>

				<div class="application-card">
					<div class="application-icon">📐</div>
					<h3>Millwork & Cabinetry</h3>
					<p>
						Dependable material for cabinet manufacturers and millwork shops producing
						standardized products or large custom orders.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="gallery-section">
		<div class="container">
			<h2 class="section-title">Product Gallery</h2>

			<div class="gallery-grid">
				<div class="gallery-item">
					<img src="/Engineered_Black_&_White_Ebony_Veneer_(2).jpg" alt="Engineered Veneer Detail" />
				</div>
				<div class="gallery-item">
					<img src="/Engineered_Black_&_White_Ebony_Veneer_(3).jpg" alt="Consistent Grain Pattern" />
				</div>
				<div class="gallery-item">
					<img src="/Engineered_Black_&_White_Ebony_Veneer_(6).jpg" alt="Commercial Application" />
				</div>
				<div class="gallery-item">
					<img src="/Engineered_Black_&_White_Ebony_Veneer_(7).jpg" alt="Furniture Production" />
				</div>
			</div>
		</div>
	</section>

	<section class="comparison-section">
		<div class="container">
			<h2 class="section-title">When to Choose Engineered Veneer</h2>

			<div class="comparison-content">
				<div class="comparison-text">
					<h3>Engineered Veneer is Your Best Choice When:</h3>
					<ul>
						<li>You need consistent appearance across large production quantities</li>
						<li>Your project requires reliable batch-to-batch matching for reorders</li>
						<li>Production efficiency and reduced waste are priorities</li>
						<li>You're manufacturing furniture collections or standardized products</li>
						<li>Budget constraints favor cost-effective premium materials</li>
						<li>Supply stability and predictable delivery schedules are critical</li>
						<li>You're working on hospitality, commercial, or multi-unit residential projects</li>
					</ul>

					<p class="comparison-note">
						For bespoke luxury projects where unique natural character is desired, explore our
						<a href="/natural-veneer">Natural Black & White Ebony Veneer</a> featuring authentic
						grain variations and one-of-a-kind beauty.
					</p>
				</div>
			</div>
		</div>
	</section>

	<CTASection
		title="Partner With Us for Your Production Needs"
		description="Discuss volume pricing, custom specifications, and long-term supply agreements. Our team is ready to support your manufacturing success with reliable, high-quality engineered veneer."
		ctaText="Contact Sales Team"
		ctaLink="/contact"
		background="dark"
	/>

	<Footer />
</Layout>

<style>
	.product-intro {
		padding: var(--spacing-xl) 0;
		background: var(--color-white);
	}

	.intro-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-lg);
		align-items: center;
	}

	.intro-text h2 {
		margin-bottom: var(--spacing-md);
	}

	.intro-text p {
		font-size: 1.05rem;
		line-height: 1.8;
		margin-bottom: var(--spacing-md);
	}

	.intro-text p:last-child {
		margin-bottom: 0;
	}

	.intro-image {
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 4px 24px rgba(26, 26, 26, 0.15);
	}

	.intro-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.features-section,
	.specifications-section,
	.benefits-section,
	.applications-section,
	.gallery-section,
	.comparison-section {
		padding: var(--spacing-xl) 0;
	}

	.features-section {
		background: var(--color-ivory);
	}

	.specifications-section {
		background: var(--color-white);
	}

	.benefits-section {
		background: var(--color-ivory);
	}

	.applications-section {
		background: var(--color-white);
	}

	.gallery-section {
		background: var(--color-ivory);
	}

	.comparison-section {
		background: var(--color-white);
	}

	.section-title {
		text-align: center;
		margin-bottom: var(--spacing-xl);
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
		gap: var(--spacing-md);
	}

	.feature-item {
		background: var(--color-white);
		padding: var(--spacing-md);
		border-radius: 8px;
		box-shadow: 0 2px 12px rgba(26, 26, 26, 0.06);
		transition: all 0.3s ease;
	}

	.feature-item:hover {
		transform: translateY(-4px);
		box-shadow: 0 4px 20px rgba(26, 26, 26, 0.12);
	}

	.feature-number {
		font-family: var(--font-heading);
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--color-gold);
		margin-bottom: var(--spacing-sm);
		opacity: 0.3;
	}

	.feature-item h3 {
		font-size: 1.35rem;
		margin-bottom: var(--spacing-sm);
		color: var(--color-ebony);
	}

	.feature-item p {
		font-size: 0.95rem;
		line-height: 1.7;
	}

	.specs-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--spacing-md);
		margin-bottom: var(--spacing-lg);
	}

	.spec-card {
		background: var(--color-ivory);
		padding: var(--spacing-md);
		border-radius: 8px;
		border-left: 4px solid var(--color-gold);
	}

	.spec-card h4 {
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
		color: var(--color-ebony);
	}

	.spec-card p {
		font-size: 0.95rem;
		color: var(--color-gray);
	}

	.specs-note {
		background: var(--color-ebony);
		color: var(--color-ivory);
		padding: var(--spacing-md);
		border-radius: 8px;
		max-width: 900px;
		margin: 0 auto;
	}

	.specs-note p {
		font-size: 0.95rem;
		line-height: 1.7;
		color: var(--color-ivory);
	}

	.specs-note strong {
		color: var(--color-gold);
	}

	.benefits-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: var(--spacing-md);
	}

	.benefit-card {
		background: var(--color-white);
		padding: var(--spacing-md);
		border-radius: 8px;
		box-shadow: 0 2px 12px rgba(26, 26, 26, 0.06);
		transition: all 0.3s ease;
		text-align: center;
	}

	.benefit-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 4px 20px rgba(26, 26, 26, 0.12);
	}

	.benefit-icon {
		font-size: 3rem;
		margin-bottom: var(--spacing-sm);
	}

	.benefit-card h3 {
		font-size: 1.35rem;
		margin-bottom: var(--spacing-sm);
		color: var(--color-ebony);
	}

	.benefit-card p {
		font-size: 0.95rem;
		line-height: 1.7;
	}

	.applications-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: var(--spacing-md);
	}

	.application-card {
		background: var(--color-ivory);
		padding: var(--spacing-md);
		border-radius: 8px;
		box-shadow: 0 2px 12px rgba(26, 26, 26, 0.06);
		transition: all 0.3s ease;
		text-align: center;
	}

	.application-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 4px 20px rgba(26, 26, 26, 0.12);
	}

	.application-icon {
		font-size: 3rem;
		margin-bottom: var(--spacing-sm);
	}

	.application-card h3 {
		font-size: 1.35rem;
		margin-bottom: var(--spacing-sm);
		color: var(--color-ebony);
	}

	.application-card p {
		font-size: 0.95rem;
		line-height: 1.7;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: var(--spacing-md);
	}

	.gallery-item {
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 4px 16px rgba(26, 26, 26, 0.12);
		height: 320px;
		transition: all 0.3s ease;
	}

	.gallery-item:hover {
		transform: translateY(-4px);
		box-shadow: 0 6px 24px rgba(26, 26, 26, 0.18);
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.gallery-item:hover img {
		transform: scale(1.05);
	}

	.comparison-content {
		max-width: 900px;
		margin: 0 auto;
		background: var(--color-ivory);
		padding: var(--spacing-lg);
		border-radius: 8px;
		box-shadow: 0 2px 16px rgba(26, 26, 26, 0.08);
	}

	.comparison-text h3 {
		font-size: 1.75rem;
		margin-bottom: var(--spacing-md);
		color: var(--color-ebony);
	}

	.comparison-text ul {
		list-style: none;
		margin-bottom: var(--spacing-md);
	}

	.comparison-text li {
		padding: 0.75rem 0;
		padding-left: 2rem;
		position: relative;
		font-size: 1.05rem;
		line-height: 1.7;
		color: var(--color-gray);
	}

	.comparison-text li::before {
		content: '✓';
		position: absolute;
		left: 0;
		color: var(--color-gold);
		font-weight: 700;
		font-size: 1.2rem;
	}

	.comparison-note {
		background: var(--color-white);
		padding: var(--spacing-md);
		border-radius: 8px;
		border-left: 4px solid var(--color-gold);
		font-size: 0.95rem;
		line-height: 1.7;
	}

	.comparison-note a {
		color: var(--color-walnut);
		font-weight: 600;
		text-decoration: underline;
	}

	.comparison-note a:hover {
		color: var(--color-ebony);
	}

	@media (max-width: 1024px) {
		.intro-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-md);
		}

		.features-grid {
			grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		}
	}

	@media (max-width: 768px) {
		.product-intro,
		.features-section,
		.specifications-section,
		.benefits-section,
		.applications-section,
		.gallery-section,
		.comparison-section {
			padding: var(--spacing-lg) 0;
		}

		.section-title {
			margin-bottom: var(--spacing-md);
		}

		.gallery-grid {
			grid-template-columns: 1fr;
		}

		.comparison-content {
			padding: var(--spacing-md);
		}
	}
</style>
