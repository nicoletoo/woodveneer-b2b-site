---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import CTASection from '../../components/CTASection.astro';

export async function getStaticPaths() {
	return [
		{
			params: { slug: 'luxury-hotel-lobby-renovation' }
		}
	];
}

const { slug } = Astro.params;

// Mock project for demo - in production, would fetch from CMS or markdown files
const projects: Record<string, any> = {
	'luxury-hotel-lobby-renovation': {
		project_name: 'Luxury Hotel Lobby Renovation',
		category: 'Hospitality',
		veneer_type: 'Natural',
		featured_image: 'https://images.pexels.com/photos/1457842/pexels-photo-1457842.jpeg?auto=compress&cs=tinysrgb&w=1200',
		gallery_images: [
			'https://images.pexels.com/photos/1457842/pexels-photo-1457842.jpeg?auto=compress&cs=tinysrgb&w=800',
			'https://images.pexels.com/photos/1643389/pexels-photo-1643389.jpeg?auto=compress&cs=tinysrgb&w=800',
			'https://images.pexels.com/photos/1350789/pexels-photo-1350789.jpeg?auto=compress&cs=tinysrgb&w=800'
		],
		seo_title: 'Luxury Hotel Lobby Project | Natural Ebony Veneer Application',
		meta_description: 'Premium hotel lobby renovation using natural Black & White Ebony Veneer for dramatic architectural feature walls.',
		content: `
			<h2>Project Overview</h2>
			<p>This prestigious hotel renovation project showcased the dramatic aesthetic potential of natural Black & White Ebony Veneer in a high-traffic hospitality environment. The design vision centered on creating an unforgettable first impression through bold material selection and careful architectural detailing.</p>

			<h3>Design Objectives</h3>
			<ul>
				<li><strong>Create Premium First Impression:</strong> The lobby's entry sequence required a powerful visual statement that would set expectations for luxury throughout the property.</li>
				<li><strong>Feature Authentic Materials:</strong> The design team selected natural ebony veneer specifically for its authentic grain variations and dramatic color contrast, creating visual depth and organic artistry.</li>
				<li><strong>Support Wayfinding:</strong> Strategic veneer applications guided guest flow and defined different functional zones within the lobby space.</li>
			</ul>

			<h3>Application Details</h3>
			<p><strong>Primary Materials:</strong></p>
			<ul>
				<li>Natural Black & White Ebony Veneer, 0.6mm thickness</li>
				<li>Premium A-grade featuring varied grain patterns</li>
				<li>Paper backing for traditional veneer application</li>
				<li>Custom sizes ranging from 1200mm to 2400mm widths</li>
			</ul>

			<p><strong>Installation Locations:</strong></p>
			<ul>
				<li>Feature wall spanning 15 meters across main lobby entrance</li>
				<li>Accent panels flanking main staircase</li>
				<li>Custom veneer frames for architectural alcoves</li>
				<li>Coordinate with marble, brass, and natural stone elements</li>
			</ul>

			<p><strong>Project Specifications:</strong></p>
			<ul>
				<li>Total veneer coverage: 180 square meters</li>
				<li>Application method: Traditional contact cement</li>
				<li>Finishing: Matte polyurethane with UV protection</li>
				<li>Installation timeframe: 3 weeks on-site</li>
			</ul>

			<h3>Results & Impact</h3>
			<p>The feature wall became the lobby's visual focal point, exceeding design expectations with its dramatic presence and authentic luxury appeal. The natural veneer demonstrated exceptional durability over 18+ months of continuous use with minimal maintenance requirements, and positive feedback from guests regarding the distinctive material and premium atmosphere created by the veneer application.</p>

			<h3>Key Learnings</h3>
			<p>This project demonstrated that:</p>
			<ol>
				<li>Natural veneer's unique character adds authentic value to luxury hospitality spaces</li>
				<li>Careful grain matching across large surface areas creates cohesive design</li>
				<li>Professional installation is critical for premium appearance and durability</li>
				<li>Proper protective finishing ensures long-term performance in high-traffic environments</li>
				<li>Strategic material placement maximizes visual impact while maintaining functionality</li>
			</ol>
		`
	}
};

const project = projects[slug];

if (!project) {
	return Astro.redirect('/project');
}
---

<Layout
	title={project.seo_title}
	description={project.meta_description}
>
	<Header />

	<Hero
		title={project.project_name}
		subtitle={`${project.category} • ${project.veneer_type} Ebony Veneer`}
		imageUrl={project.featured_image}
		height="large"
	/>

	<article class="project-section">
		<div class="container">
			<div class="project-header">
				<h1 class="project-title">{project.project_name}</h1>
				<div class="project-tags">
					<span class="project-tag">{project.category}</span>
					<span class="project-tag">{project.veneer_type} Veneer</span>
				</div>
			</div>

			<div class="project-content">
				<div class="project-body" set:html={project.content} />
			</div>

			{project.gallery_images && project.gallery_images.length > 0 && (
				<div class="project-gallery">
					<h2>Project Gallery</h2>
					<div class="gallery-grid">
						{project.gallery_images.map(image => (
							<div class="gallery-item">
								<img src={image} alt="Project gallery" />
							</div>
						))}
					</div>
				</div>
			)}

			<div class="project-footer">
				<a href="/project" class="back-link">← Back to Projects</a>
			</div>
		</div>
	</article>

	<CTASection
		title="Ready to Discuss Your Project?"
		description="Whether you're planning a hospitality installation, furniture collection, or architectural application, our team is ready to support your vision with premium Black & White Ebony Veneer."
		ctaText="Contact Us Today"
		ctaLink="/contact"
		background="dark"
	/>

	<Footer />
</Layout>

<style>
	.project-section {
		padding: var(--spacing-xl) 0;
		background: var(--color-white);
	}

	.project-header {
		max-width: 900px;
		margin: 0 auto var(--spacing-xl);
	}

	.project-title {
		font-size: clamp(2rem, 4vw, 3.5rem);
		color: var(--color-ebony);
		margin-bottom: var(--spacing-md);
	}

	.project-tags {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.project-tag {
		display: inline-block;
		background: var(--color-ivory);
		color: var(--color-ebony);
		padding: 0.5rem 1.25rem;
		font-size: 0.9rem;
		font-weight: 500;
		border-radius: 50px;
		border: 1px solid var(--color-gold);
	}

	.project-content {
		max-width: 900px;
		margin: 0 auto var(--spacing-xl);
	}

	.project-body {
		font-size: 1.05rem;
		line-height: 1.8;
		color: var(--color-gray);
	}

	.project-body h2 {
		margin-top: var(--spacing-lg);
		margin-bottom: var(--spacing-md);
		color: var(--color-ebony);
	}

	.project-body h3 {
		margin-top: var(--spacing-md);
		margin-bottom: var(--spacing-sm);
		color: var(--color-ebony);
	}

	.project-body p {
		margin-bottom: var(--spacing-md);
	}

	.project-body ul,
	.project-body ol {
		margin: var(--spacing-md) 0;
		padding-left: 2rem;
	}

	.project-body li {
		margin-bottom: 0.75rem;
	}

	.project-gallery {
		margin-top: var(--spacing-xl);
	}

	.project-gallery h2 {
		margin-bottom: var(--spacing-lg);
		color: var(--color-ebony);
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: var(--spacing-md);
	}

	.gallery-item {
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 4px 16px rgba(26, 26, 26, 0.12);
		height: 320px;
		transition: all 0.3s ease;
	}

	.gallery-item:hover {
		transform: translateY(-4px);
		box-shadow: 0 6px 24px rgba(26, 26, 26, 0.18);
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.gallery-item:hover img {
		transform: scale(1.05);
	}

	.project-footer {
		margin-top: var(--spacing-xl);
		padding-top: var(--spacing-lg);
		border-top: 1px solid var(--color-ivory);
	}

	.back-link {
		display: inline-block;
		color: var(--color-ebony);
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.back-link:hover {
		color: var(--color-walnut);
	}

	@media (max-width: 768px) {
		.project-section {
			padding: var(--spacing-lg) 0;
		}

		.project-body {
			font-size: 1rem;
		}

		.gallery-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
