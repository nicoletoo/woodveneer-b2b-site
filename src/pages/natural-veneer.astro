---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout
	title="Natural Black & White Ebony Veneer | Premium Wood Veneer | woodveneer.net"
	description="Authentic Natural Black & White Ebony Veneer with unique grain patterns and dramatic contrast. Premium quality for luxury furniture, interior design, and high-end decorative projects."
>
	<Header />

	<Hero
		title="Natural Black & White Ebony Veneer"
		subtitle="Authentic natural wood veneer showcasing the unique character and dramatic contrast of genuine ebony timber for exceptional luxury projects."
		cta1Text="Request Samples"
		cta1Link="/contact"
		cta2Text="View Projects"
		cta2Link="/project"
		imageUrl="/Black_and_White_Ebony_Wood_Veneer_(2)(1).jpg"
		height="large"
		overlayOpacity={0.35}
	/>

	<section class="product-intro">
		<div class="container">
			<div class="intro-grid">
				<div class="intro-text">
					<h2>Authentic Natural Beauty</h2>
					<p>
						Our Natural Black & White Ebony Veneer is carefully selected from premium timber sources,
						showcasing the extraordinary natural grain patterns and distinctive black-and-white contrast
						that make ebony one of the most sought-after decorative woods in the world.
					</p>
					<p>
						Each veneer sheet is a unique piece of nature's artistry, featuring organic variations in
						grain direction, color intensity, and pattern complexity. This natural character makes
						every application truly one-of-a-kind, perfect for luxury furniture manufacturers, interior
						designers, and architects seeking authentic premium materials.
					</p>
				</div>
				<div class="intro-image">
					<img src="/Black_and_White_Ebony_Wood_Veneer_(5).jpg" alt="Natural Ebony Veneer" />
				</div>
			</div>
		</div>
	</section>

	<section class="features-section">
		<div class="container">
			<h2 class="section-title">Key Features & Benefits</h2>

			<div class="features-grid">
				<div class="feature-item">
					<div class="feature-number">01</div>
					<h3>Unique Natural Grain Patterns</h3>
					<p>
						Every sheet displays distinct grain characteristics, ensuring no two pieces are identical.
						The natural variation adds authentic luxury and exclusivity to your projects.
					</p>
				</div>

				<div class="feature-item">
					<div class="feature-number">02</div>
					<h3>Dramatic Black & White Contrast</h3>
					<p>
						Striking natural color contrast creates visual impact and sophisticated aesthetic appeal,
						perfect for statement furniture pieces and high-end interior applications.
					</p>
				</div>

				<div class="feature-item">
					<div class="feature-number">03</div>
					<h3>Premium Decorative Value</h3>
					<p>
						Natural ebony veneer commands attention and conveys luxury, making it ideal for
						prestigious projects that demand the finest materials.
					</p>
				</div>

				<div class="feature-item">
					<div class="feature-number">04</div>
					<h3>Superior Surface Quality</h3>
					<p>
						Carefully processed to maintain smooth, clean surfaces suitable for high-quality finishing.
						Accepts stains, lacquers, and protective coatings beautifully.
					</p>
				</div>

				<div class="feature-item">
					<div class="feature-number">05</div>
					<h3>Excellent Workability</h3>
					<p>
						Our natural veneer is prepared for professional application, compatible with standard
						veneer bonding techniques and woodworking processes.
					</p>
				</div>

				<div class="feature-item">
					<div class="feature-number">06</div>
					<h3>Sustainable Sourcing</h3>
					<p>
						We prioritize responsible forestry practices and work with certified suppliers to ensure
						environmental stewardship throughout our supply chain.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="specifications-section">
		<div class="container">
			<h2 class="section-title">Specifications</h2>

			<div class="specs-grid">
				<div class="spec-card">
					<h4>Thickness Options</h4>
					<p>0.5mm, 0.6mm, custom thickness available</p>
				</div>

				<div class="spec-card">
					<h4>Width Range</h4>
					<p>100mm - 640mm (varies by availability)</p>
				</div>

				<div class="spec-card">
					<h4>Length Range</h4>
					<p>2440mm - 3050mm standard, custom lengths available</p>
				</div>

				<div class="spec-card">
					<h4>Backing Options</h4>
					<p>Paper backing, fleece backing, or unbacked upon request</p>
				</div>

				<div class="spec-card">
					<h4>Moisture Content</h4>
					<p>8-12% properly conditioned for stability</p>
				</div>

				<div class="spec-card">
					<h4>Grade</h4>
					<p>Premium A-grade with natural character variations</p>
				</div>

				<div class="spec-card">
					<h4>Grain Pattern</h4>
					<p>Natural straight, interlocked, or figured grain</p>
				</div>

				<div class="spec-card">
					<h4>Packaging</h4>
					<p>Protective packaging suitable for international shipping</p>
				</div>
			</div>

			<div class="specs-note">
				<p>
					<strong>Note:</strong> As a natural product, exact dimensions and appearance vary by individual sheet.
					We recommend ordering samples to evaluate grain patterns and color for your specific application.
					Custom sizing and processing options available for large projects.
				</p>
			</div>
		</div>
	</section>

	<section class="applications-section">
		<div class="container">
			<h2 class="section-title">Recommended Applications</h2>

			<div class="applications-grid">
				<div class="application-card">
					<div class="application-icon">🪑</div>
					<h3>Luxury Furniture</h3>
					<p>
						High-end table tops, cabinet doors, furniture panels, and decorative inlays for
						luxury residential and commercial furniture collections.
					</p>
				</div>

				<div class="application-card">
					<div class="application-icon">🏢</div>
					<h3>Interior Wall Panels</h3>
					<p>
						Feature walls, decorative wall cladding, and architectural paneling for
						upscale residences, hotels, and executive offices.
					</p>
				</div>

				<div class="application-card">
					<div class="application-icon">🚪</div>
					<h3>Premium Doors</h3>
					<p>
						Luxury door skins and architectural millwork where natural character and
						uniqueness are desired design elements.
					</p>
				</div>

				<div class="application-card">
					<div class="application-icon">✨</div>
					<h3>Bespoke Interior Design</h3>
					<p>
						Custom furniture pieces, decorative screens, reception desks, and unique
						architectural features for exclusive projects.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="gallery-section">
		<div class="container">
			<h2 class="section-title">Product Gallery</h2>

			<div class="gallery-grid">
				<div class="gallery-item">
					<img src="/Black_and_White_Ebony_Wood_Veneer_(2)(1).jpg" alt="Natural Ebony Veneer Detail" />
				</div>
				<div class="gallery-item">
					<img src="/Black_and_White_Ebony_Wood_Veneer_(2)(2).jpg" alt="Ebony Wood Grain Pattern" />
				</div>
				<div class="gallery-item">
					<img src="/Black_and_White_Ebony_Wood_Veneer_(5).jpg" alt="Natural Veneer Application" />
				</div>
				<div class="gallery-item">
					<img src="/微信图片_20260326102352_1017_148(1).jpg" alt="Natural Veneer Sheet" />
				</div>
			</div>
		</div>
	</section>

	<section class="comparison-section">
		<div class="container">
			<h2 class="section-title">Why Choose Natural Over Engineered?</h2>

			<div class="comparison-content">
				<div class="comparison-text">
					<h3>When Natural Veneer is the Right Choice:</h3>
					<ul>
						<li>You want truly unique, one-of-a-kind pieces with natural character</li>
						<li>Your project values authentic material provenance and natural beauty</li>
						<li>You're creating bespoke furniture or custom interior elements</li>
						<li>Natural grain variation is a desired design feature</li>
						<li>You're working on luxury residential or exclusive commercial projects</li>
						<li>Each piece can be individually evaluated and matched</li>
					</ul>

					<p class="comparison-note">
						For projects requiring consistent appearance across large quantities, consider our
						<a href="/engineered-veneer">Engineered Black & White Ebony Veneer</a> for better
						batch consistency and scalability.
					</p>
				</div>
			</div>
		</div>
	</section>

	<CTASection
		title="Request Natural Ebony Veneer Samples"
		description="Experience the authentic beauty of Natural Black & White Ebony Veneer firsthand. Contact us to receive samples, discuss your project requirements, and explore custom sizing options."
		ctaText="Request Samples"
		ctaLink="/contact"
		background="dark"
	/>

	<Footer />
</Layout>

<style>
	.product-intro {
		padding: var(--spacing-xl) 0;
		background: var(--color-white);
	}

	.intro-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-lg);
		align-items: center;
	}

	.intro-text h2 {
		margin-bottom: var(--spacing-md);
	}

	.intro-text p {
		font-size: 1.05rem;
		line-height: 1.8;
		margin-bottom: var(--spacing-md);
	}

	.intro-text p:last-child {
		margin-bottom: 0;
	}

	.intro-image {
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 4px 24px rgba(26, 26, 26, 0.15);
	}

	.intro-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.features-section,
	.specifications-section,
	.applications-section,
	.gallery-section,
	.comparison-section {
		padding: var(--spacing-xl) 0;
	}

	.features-section {
		background: var(--color-ivory);
	}

	.specifications-section {
		background: var(--color-white);
	}

	.applications-section {
		background: var(--color-ivory);
	}

	.gallery-section {
		background: var(--color-white);
	}

	.comparison-section {
		background: var(--color-ivory);
	}

	.section-title {
		text-align: center;
		margin-bottom: var(--spacing-xl);
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
		gap: var(--spacing-md);
	}

	.feature-item {
		background: var(--color-white);
		padding: var(--spacing-md);
		border-radius: 8px;
		box-shadow: 0 2px 12px rgba(26, 26, 26, 0.06);
		transition: all 0.3s ease;
	}

	.feature-item:hover {
		transform: translateY(-4px);
		box-shadow: 0 4px 20px rgba(26, 26, 26, 0.12);
	}

	.feature-number {
		font-family: var(--font-heading);
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--color-gold);
		margin-bottom: var(--spacing-sm);
		opacity: 0.3;
	}

	.feature-item h3 {
		font-size: 1.35rem;
		margin-bottom: var(--spacing-sm);
		color: var(--color-ebony);
	}

	.feature-item p {
		font-size: 0.95rem;
		line-height: 1.7;
	}

	.specs-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--spacing-md);
		margin-bottom: var(--spacing-lg);
	}

	.spec-card {
		background: var(--color-ivory);
		padding: var(--spacing-md);
		border-radius: 8px;
		border-left: 4px solid var(--color-gold);
	}

	.spec-card h4 {
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
		color: var(--color-ebony);
	}

	.spec-card p {
		font-size: 0.95rem;
		color: var(--color-gray);
	}

	.specs-note {
		background: var(--color-ebony);
		color: var(--color-ivory);
		padding: var(--spacing-md);
		border-radius: 8px;
		max-width: 900px;
		margin: 0 auto;
	}

	.specs-note p {
		font-size: 0.95rem;
		line-height: 1.7;
		color: var(--color-ivory);
	}

	.specs-note strong {
		color: var(--color-gold);
	}

	.applications-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: var(--spacing-md);
	}

	.application-card {
		background: var(--color-white);
		padding: var(--spacing-md);
		border-radius: 8px;
		box-shadow: 0 2px 12px rgba(26, 26, 26, 0.06);
		transition: all 0.3s ease;
		text-align: center;
	}

	.application-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 4px 20px rgba(26, 26, 26, 0.12);
	}

	.application-icon {
		font-size: 3rem;
		margin-bottom: var(--spacing-sm);
	}

	.application-card h3 {
		font-size: 1.35rem;
		margin-bottom: var(--spacing-sm);
		color: var(--color-ebony);
	}

	.application-card p {
		font-size: 0.95rem;
		line-height: 1.7;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: var(--spacing-md);
	}

	.gallery-item {
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 4px 16px rgba(26, 26, 26, 0.12);
		height: 320px;
		transition: all 0.3s ease;
	}

	.gallery-item:hover {
		transform: translateY(-4px);
		box-shadow: 0 6px 24px rgba(26, 26, 26, 0.18);
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.gallery-item:hover img {
		transform: scale(1.05);
	}

	.comparison-content {
		max-width: 900px;
		margin: 0 auto;
		background: var(--color-white);
		padding: var(--spacing-lg);
		border-radius: 8px;
		box-shadow: 0 2px 16px rgba(26, 26, 26, 0.08);
	}

	.comparison-text h3 {
		font-size: 1.75rem;
		margin-bottom: var(--spacing-md);
		color: var(--color-ebony);
	}

	.comparison-text ul {
		list-style: none;
		margin-bottom: var(--spacing-md);
	}

	.comparison-text li {
		padding: 0.75rem 0;
		padding-left: 2rem;
		position: relative;
		font-size: 1.05rem;
		line-height: 1.7;
		color: var(--color-gray);
	}

	.comparison-text li::before {
		content: '✓';
		position: absolute;
		left: 0;
		color: var(--color-gold);
		font-weight: 700;
		font-size: 1.2rem;
	}

	.comparison-note {
		background: var(--color-ivory);
		padding: var(--spacing-md);
		border-radius: 8px;
		border-left: 4px solid var(--color-gold);
		font-size: 0.95rem;
		line-height: 1.7;
	}

	.comparison-note a {
		color: var(--color-walnut);
		font-weight: 600;
		text-decoration: underline;
	}

	.comparison-note a:hover {
		color: var(--color-ebony);
	}

	@media (max-width: 1024px) {
		.intro-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-md);
		}

		.features-grid {
			grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		}
	}

	@media (max-width: 768px) {
		.product-intro,
		.features-section,
		.specifications-section,
		.applications-section,
		.gallery-section,
		.comparison-section {
			padding: var(--spacing-lg) 0;
		}

		.section-title {
			margin-bottom: var(--spacing-md);
		}

		.gallery-grid {
			grid-template-columns: 1fr;
		}

		.comparison-content {
			padding: var(--spacing-md);
		}
	}
</style>
