---
interface Props {
	title: string;
	description: string;
	imageUrl: string;
	link: string;
	features?: string[];
}

const { title, description, imageUrl, link, features } = Astro.props;
---

<article class="product-card">
	<div class="product-image">
		<img src={imageUrl} alt={title} />
		<div class="product-overlay"></div>
	</div>

	<div class="product-content">
		<h3 class="product-title">{title}</h3>
		<p class="product-description">{description}</p>

		{features && features.length > 0 && (
			<ul class="product-features">
				{features.map(feature => (
					<li>{feature}</li>
				))}
			</ul>
		)}

		<a href={link} class="product-link">
			Explore Details
			<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</a>
	</div>
</article>

<style>
	.product-card {
		background: var(--color-white);
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 2px 16px rgba(26, 26, 26, 0.08);
		transition: all 0.4s ease;
		height: 100%;
		display: flex;
		flex-direction: column;
	}

	.product-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 8px 32px rgba(26, 26, 26, 0.15);
	}

	.product-image {
		position: relative;
		height: 320px;
		overflow: hidden;
	}

	.product-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.product-card:hover .product-image img {
		transform: scale(1.05);
	}

	.product-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(to bottom, transparent 0%, rgba(26, 26, 26, 0.3) 100%);
	}

	.product-content {
		padding: var(--spacing-md);
		flex: 1;
		display: flex;
		flex-direction: column;
	}

	.product-title {
		font-size: 1.75rem;
		margin-bottom: var(--spacing-sm);
		color: var(--color-ebony);
	}

	.product-description {
		font-size: 1rem;
		line-height: 1.7;
		margin-bottom: var(--spacing-md);
		color: var(--color-gray);
	}

	.product-features {
		list-style: none;
		margin-bottom: var(--spacing-md);
	}

	.product-features li {
		padding: 0.5rem 0;
		color: var(--color-gray);
		font-size: 0.95rem;
		position: relative;
		padding-left: 1.5rem;
	}

	.product-features li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 50%;
		transform: translateY(-50%);
		width: 6px;
		height: 6px;
		background: var(--color-gold);
		border-radius: 50%;
	}

	.product-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--color-ebony);
		font-weight: 500;
		font-size: 1rem;
		margin-top: auto;
		transition: all 0.3s ease;
	}

	.product-link:hover {
		color: var(--color-gold);
		gap: 0.75rem;
	}

	.product-link svg {
		transition: transform 0.3s ease;
	}

	.product-link:hover svg {
		transform: translateX(4px);
	}

	@media (max-width: 768px) {
		.product-image {
			height: 240px;
		}

		.product-title {
			font-size: 1.5rem;
		}
	}
</style>
