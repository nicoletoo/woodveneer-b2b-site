---
const currentPath = Astro.url.pathname;

const navItems = [
	{ name: 'Home', path: '/' },
	{ name: 'Natural Veneer', path: '/natural-veneer' },
	{ name: 'Engineered Veneer', path: '/engineered-veneer' },
	{ name: 'News', path: '/news' },
	{ name: 'Project', path: '/project' },
	{ name: 'Contact', path: '/contact' }
];
---

<header class="header">
	<nav class="nav container">
		<a href="/" class="logo">
			<span class="logo-text">woodveneer<span class="logo-domain">.net</span></span>
		</a>

		<button class="mobile-toggle" aria-label="Toggle menu">
			<span></span>
			<span></span>
			<span></span>
		</button>

		<ul class="nav-list">
			{navItems.map(item => (
				<li>
					<a
						href={item.path}
						class={`nav-link ${currentPath === item.path ? 'active' : ''}`}
					>
						{item.name}
					</a>
				</li>
			))}
		</ul>
	</nav>
</header>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: rgba(250, 250, 248, 0.95);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(26, 26, 26, 0.08);
		transition: all 0.3s ease;
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-top: 1.5rem;
		padding-bottom: 1.5rem;
	}

	.logo {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 600;
		color: var(--color-ebony);
		transition: color 0.3s ease;
	}

	.logo:hover {
		color: var(--color-walnut);
	}

	.logo-domain {
		color: var(--color-gold);
	}

	.nav-list {
		display: flex;
		list-style: none;
		gap: 3rem;
		align-items: center;
	}

	.nav-link {
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--color-gray);
		transition: color 0.3s ease;
		position: relative;
		letter-spacing: 0.3px;
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: -4px;
		left: 0;
		width: 0;
		height: 2px;
		background: var(--color-ebony);
		transition: width 0.3s ease;
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--color-ebony);
	}

	.nav-link:hover::after,
	.nav-link.active::after {
		width: 100%;
	}

	.mobile-toggle {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		padding: 0.5rem;
	}

	.mobile-toggle span {
		width: 25px;
		height: 2px;
		background: var(--color-ebony);
		transition: all 0.3s ease;
	}

	@media (max-width: 768px) {
		.nav-list {
			position: fixed;
			top: 73px;
			left: -100%;
			width: 100%;
			height: calc(100vh - 73px);
			background: var(--color-off-white);
			flex-direction: column;
			justify-content: flex-start;
			padding: 3rem 2rem;
			gap: 2rem;
			transition: left 0.3s ease;
		}

		.nav-list.active {
			left: 0;
		}

		.mobile-toggle {
			display: flex;
		}

		.nav-link {
			font-size: 1.25rem;
		}
	}
</style>

<script>
	const mobileToggle = document.querySelector('.mobile-toggle');
	const navList = document.querySelector('.nav-list');

	if (mobileToggle && navList) {
		mobileToggle.addEventListener('click', () => {
			navList.classList.toggle('active');
		});

		document.querySelectorAll('.nav-link').forEach(link => {
			link.addEventListener('click', () => {
				navList.classList.remove('active');
			});
		});
	}
</script>
