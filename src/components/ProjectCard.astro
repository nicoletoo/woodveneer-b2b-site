---
interface Props {
	title: string;
	category: string;
	imageUrl: string;
	description: string;
}

const { title, category, imageUrl, description } = Astro.props;
---

<article class="project-card">
	<div class="project-image">
		<img src={imageUrl} alt={title} />
		<div class="project-overlay">
			<div class="project-info">
				<span class="project-category">{category}</span>
				<h3 class="project-title">{title}</h3>
				<p class="project-description">{description}</p>
			</div>
		</div>
	</div>
</article>

<style>
	.project-card {
		position: relative;
		border-radius: 8px;
		overflow: hidden;
		height: 400px;
		box-shadow: 0 2px 16px rgba(26, 26, 26, 0.08);
		transition: all 0.4s ease;
	}

	.project-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 8px 32px rgba(26, 26, 26, 0.15);
	}

	.project-image {
		width: 100%;
		height: 100%;
		position: relative;
	}

	.project-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.project-card:hover .project-image img {
		transform: scale(1.1);
	}

	.project-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(to bottom, transparent 0%, rgba(26, 26, 26, 0.9) 100%);
		display: flex;
		align-items: flex-end;
		padding: var(--spacing-md);
		transition: background 0.4s ease;
	}

	.project-card:hover .project-overlay {
		background: linear-gradient(to bottom, rgba(26, 26, 26, 0.3) 0%, rgba(26, 26, 26, 0.95) 100%);
	}

	.project-info {
		width: 100%;
	}

	.project-category {
		display: inline-block;
		color: var(--color-gold);
		font-size: 0.85rem;
		font-weight: 500;
		letter-spacing: 1px;
		text-transform: uppercase;
		margin-bottom: 0.5rem;
	}

	.project-title {
		color: var(--color-ivory);
		font-size: 1.75rem;
		margin-bottom: 0.75rem;
		transition: color 0.3s ease;
	}

	.project-card:hover .project-title {
		color: var(--color-gold);
	}

	.project-description {
		color: var(--color-ivory);
		font-size: 0.95rem;
		line-height: 1.6;
		opacity: 0;
		transform: translateY(10px);
		transition: all 0.4s ease;
	}

	.project-card:hover .project-description {
		opacity: 1;
		transform: translateY(0);
	}

	@media (max-width: 768px) {
		.project-card {
			height: 320px;
		}

		.project-title {
			font-size: 1.5rem;
		}
	}
</style>
